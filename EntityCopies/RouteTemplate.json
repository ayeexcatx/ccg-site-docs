{
  "name": "RouteTemplate",
  "type": "object",
  "properties": {
    "template_name": {
      "type": "string"
    },
    "client_organization_id": {
      "type": "string"
    },
    "municipality": {
      "type": "string"
    },
    "street_name": {
      "type": "string"
    },
    "segment_type": {
      "type": "string",
      "enum": [
        "street",
        "block",
        "curb_ramp_group",
        "intersection_group",
        "custom_segment"
      ]
    },
    "side_of_street": {
      "type": "string",
      "enum": [
        "right",
        "left",
        "center",
        "both",
        "not_applicable"
      ]
    },
    "default_view_type": {
      "type": "string"
    },
    "polyline_json": {
      "type": "string"
    },
    "checkpoint_template_json": {
      "type": "string"
    },
    "active": {
      "type": "boolean",
      "default": true
    },
    "internal_notes": {
      "type": "string"
    }
  },
  "required": [
    "template_name"
  ]
}
