{
  "name": "AssetLocation",
  "type": "object",
  "properties": {
    "project_id": {
      "type": "string"
    },
    "street_segment_id": {
      "type": "string"
    },
    "asset_type": {
      "type": "string",
      "enum": [
        "intersection",
        "curb_ramp",
        "driveway",
        "sidewalk_panel",
        "sign",
        "utility_structure",
        "business",
        "landmark",
        "property_frontage",
        "custom"
      ],
      "default": "intersection"
    },
    "asset_name": {
      "type": "string"
    },
    "street_address": {
      "type": "string"
    },
    "cross_street": {
      "type": "string"
    },
    "business_name": {
      "type": "string"
    },
    "map_latitude": {
      "type": "number"
    },
    "map_longitude": {
      "type": "number"
    },
    "address_range_label": {
      "type": "string"
    },
    "reference_description": {
      "type": "string"
    },
    "internal_notes": {
      "type": "string"
    },
    "client_visible_notes": {
      "type": "string"
    }
  },
  "required": [
    "project_id",
    "asset_type",
    "asset_name"
  ]
}
