{
  "name": "SystemInstruction",
  "type": "object",
  "properties": {
    "instruction_key": {
      "type": "string"
    },
    "instruction_title": {
      "type": "string"
    },
    "instruction_category": {
      "type": "string",
      "enum": [
        "workflow",
        "data_entry",
        "qa",
        "publishing",
        "client_portal",
        "mapping",
        "media",
        "gps",
        "sync",
        "timeline",
        "security"
      ],
      "default": "workflow"
    },
    "instruction_body": {
      "type": "string"
    },
    "target_role_json": {
      "type": "string",
      "description": "JSON array of roles that should see this instruction"
    },
    "target_page": {
      "type": "string"
    },
    "related_entity_name": {
      "type": "string"
    },
    "is_active": {
      "type": "boolean",
      "default": true
    },
    "sort_order": {
      "type": "number",
      "default": 0
    }
  },
  "required": [
    "instruction_key",
    "instruction_title",
    "instruction_body"
  ]
}
