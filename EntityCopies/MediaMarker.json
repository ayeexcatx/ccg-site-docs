{
  "name": "MediaMarker",
  "type": "object",
  "properties": {
    "project_id": {
      "type": "string"
    },
    "street_segment_id": {
      "type": "string"
    },
    "capture_session_id": {
      "type": "string"
    },
    "media_file_id": {
      "type": "string"
    },
    "route_checkpoint_id": {
      "type": "string"
    },
    "asset_location_id": {
      "type": "string"
    },
    "marker_type": {
      "type": "string",
      "enum": [
        "start",
        "end",
        "intersection",
        "curb_ramp",
        "address_anchor",
        "landmark",
        "issue_note",
        "business",
        "sign",
        "custom"
      ],
      "default": "intersection"
    },
    "marker_label": {
      "type": "string"
    },
    "timestamp_seconds": {
      "type": "number"
    },
    "approximate_position_percent": {
      "type": "number"
    },
    "map_latitude": {
      "type": "number"
    },
    "map_longitude": {
      "type": "number"
    },
    "search_tags_json": {
      "type": "string"
    },
    "confidence_level": {
      "type": "string",
      "enum": [
        "manual",
        "estimated",
        "confirmed",
        "ai_suggested_future"
      ],
      "default": "manual"
    },
    "internal_notes": {
      "type": "string"
    },
    "client_visible_notes": {
      "type": "string"
    },
    "is_client_visible": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
    "project_id",
    "media_file_id",
    "marker_type",
    "marker_label"
  ]
}
