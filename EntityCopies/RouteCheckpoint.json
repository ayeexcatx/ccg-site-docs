{
  "name": "RouteCheckpoint",
  "type": "object",
  "properties": {
    "project_id": {
      "type": "string"
    },
    "street_segment_id": {
      "type": "string"
    },
    "capture_session_id": {
      "type": "string"
    },
    "route_path_id": {
      "type": "string"
    },
    "checkpoint_type": {
      "type": "string",
      "enum": [
        "start",
        "end",
        "intersection",
        "curb_ramp",
        "address_anchor",
        "landmark",
        "issue_note",
        "custom"
      ],
      "default": "intersection"
    },
    "checkpoint_label": {
      "type": "string"
    },
    "sequence_order": {
      "type": "number",
      "default": 0
    },
    "map_latitude": {
      "type": "number"
    },
    "map_longitude": {
      "type": "number"
    },
    "related_asset_location_id": {
      "type": "string"
    },
    "expected_timestamp_seconds": {
      "type": "number"
    },
    "confirmed_timestamp_seconds": {
      "type": "number"
    },
    "is_client_visible": {
      "type": "boolean",
      "default": true
    },
    "internal_notes": {
      "type": "string"
    },
    "client_visible_notes": {
      "type": "string"
    }
  },
  "required": [
    "project_id",
    "checkpoint_type",
    "checkpoint_label"
  ]
}
