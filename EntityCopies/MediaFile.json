{
  "name": "MediaFile",
  "type": "object",
  "properties": {
    "project_id": {
      "type": "string"
    },
    "street_segment_id": {
      "type": "string"
    },
    "capture_session_id": {
      "type": "string"
    },
    "upload_batch_id": {
      "type": "string"
    },
    "media_type": {
      "type": "string",
      "enum": [
        "photo",
        "video",
        "video_360",
        "thumbnail",
        "preview_clip",
        "document",
        "export"
      ],
      "default": "video"
    },
    "media_title": {
      "type": "string"
    },
    "media_title_override_for_client": {
      "type": "string"
    },
    "original_filename": {
      "type": "string"
    },
    "source_kind": {
      "type": "string",
      "enum": [
        "native_upload",
        "external_link"
      ],
      "default": "native_upload"
    },
    "storage_mode": {
      "type": "string",
      "enum": [
        "native_upload",
        "external_link",
        "future_connector_storage"
      ],
      "default": "native_upload"
    },
    "original_file_policy": {
      "type": "string",
      "enum": [
        "keep_in_app",
        "register_external_master",
        "archive_external_master"
      ],
      "default": "keep_in_app"
    },
    "file_url": {
      "type": "string"
    },
    "original_file_url": {
      "type": "string"
    },
    "preview_url": {
      "type": "string"
    },
    "preview_status": {
      "type": "string",
      "enum": [
        "missing",
        "queued",
        "ready",
        "error"
      ],
      "default": "missing"
    },
    "thumbnail_url": {
      "type": "string"
    },
    "thumbnail_status": {
      "type": "string",
      "enum": [
        "missing",
        "queued",
        "ready",
        "error"
      ],
      "default": "missing"
    },
    "external_storage_label": {
      "type": "string"
    },
    "external_storage_path": {
      "type": "string"
    },
    "mime_type": {
      "type": "string"
    },
    "duration_seconds": {
      "type": "number"
    },
    "file_size_bytes": {
      "type": "number"
    },
    "resolution_label": {
      "type": "string"
    },
    "capture_device": {
      "type": "string"
    },
    "capture_datetime": {
      "type": "string"
    },
    "upload_datetime": {
      "type": "string"
    },
    "uploaded_by": {
      "type": "string"
    },
    "is_long_form": {
      "type": "boolean",
      "default": false
    },
    "long_form_minutes": {
      "type": "number"
    },
    "is_360_media": {
      "type": "boolean",
      "default": false
    },
    "view_type": {
      "type": "string",
      "enum": [
        "profile",
        "curb_line_edge_of_pavement",
        "cross_section",
        "360_walk",
        "reverse_view",
        "custom"
      ],
      "default": "profile"
    },
    "direction_label": {
      "type": "string"
    },
    "side_of_street": {
      "type": "string",
      "enum": [
        "right",
        "left",
        "center",
        "both",
        "not_applicable"
      ]
    },
    "is_primary_for_segment": {
      "type": "boolean",
      "default": false
    },
    "publish_to_client": {
      "type": "boolean",
      "default": false
    },
    "publish_readiness": {
      "type": "string",
      "enum": [
        "not_reviewed",
        "needs_preview",
        "needs_thumbnail",
        "qa_hold",
        "ready_for_publish",
        "published"
      ],
      "default": "not_reviewed"
    },
    "client_safe_media_id": {
      "type": "string"
    },
    "processing_status": {
      "type": "string",
      "enum": [
        "uploaded",
        "processing",
        "ready",
        "error",
        "archived"
      ],
      "default": "uploaded"
    },
    "internal_notes": {
      "type": "string"
    },
    "client_visible_notes": {
      "type": "string"
    }
  },
  "required": [
    "project_id",
    "media_type",
    "media_title"
  ]
}
