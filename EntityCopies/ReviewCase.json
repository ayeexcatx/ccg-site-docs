{
  "name": "ReviewCase",
  "type": "object",
  "properties": {
    "project_id": {
      "type": "string"
    },
    "client_organization_id": {
      "type": "string"
    },
    "case_title": {
      "type": "string"
    },
    "case_type": {
      "type": "string",
      "enum": [
        "claim_review",
        "internal_review",
        "qa_review",
        "client_question",
        "export_request"
      ],
      "default": "internal_review"
    },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "in_progress",
        "resolved",
        "closed"
      ],
      "default": "open"
    },
    "submitted_by_user_id": {
      "type": "string"
    },
    "related_address": {
      "type": "string"
    },
    "related_intersection": {
      "type": "string"
    },
    "related_business": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "internal_notes": {
      "type": "string"
    },
    "client_visible_notes": {
      "type": "string"
    }
  },
  "required": [
    "case_title",
    "case_type"
  ]
}
