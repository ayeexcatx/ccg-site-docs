{
  "name": "TimelineIndexItem",
  "type": "object",
  "properties": {
    "project_id": { "type": "string" },
    "capture_session_id": { "type": "string" },
    "capture_session_entry_id": { "type": "string" },
    "media_file_id": { "type": "string" },
    "gps_track_id": { "type": "string" },
    "timeline_title": { "type": "string" },
    "timeline_summary": { "type": "string" },
    "timeline_timestamp": { "type": "string" },
    "search_text": { "type": "string" },
    "search_keywords": { "type": "string" },
    "index_status": {
      "type": "string",
      "enum": ["indexed", "needs_review", "hidden"],
      "default": "indexed"
    },
    "publish_to_client": { "type": "boolean", "default": false }
  },
  "required": ["project_id", "timeline_title"]
}
