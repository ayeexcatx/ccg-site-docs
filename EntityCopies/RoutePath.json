{
  "name": "RoutePath",
  "type": "object",
  "properties": {
    "project_id": {
      "type": "string"
    },
    "street_segment_id": {
      "type": "string"
    },
    "capture_session_id": {
      "type": "string"
    },
    "route_name": {
      "type": "string"
    },
    "route_mode": {
      "type": "string",
      "enum": [
        "drawn_on_map",
        "copied_template",
        "generated_simple",
        "gps_import_future"
      ],
      "default": "drawn_on_map"
    },
    "polyline_json": {
      "type": "string",
      "description": "JSON array of lat/lng points"
    },
    "start_latitude": {
      "type": "number"
    },
    "start_longitude": {
      "type": "number"
    },
    "end_latitude": {
      "type": "number"
    },
    "end_longitude": {
      "type": "number"
    },
    "estimated_distance": {
      "type": "string"
    },
    "has_checkpoints": {
      "type": "boolean",
      "default": false
    },
    "map_bounds_json": {
      "type": "string"
    },
    "internal_notes": {
      "type": "string"
    }
  },
  "required": [
    "project_id",
    "route_name"
  ]
}
