{
  "name": "GpsTrack",
  "type": "object",
  "properties": {
    "project_id": {
      "type": "string"
    },
    "capture_session_id": {
      "type": "string"
    },
    "source_type": {
      "type": "string",
      "enum": [
        "gpx",
        "fit",
        "geojson",
        "device_sync",
        "manual"
      ],
      "default": "gpx"
    },
    "original_filename": {
      "type": "string"
    },
    "file_url": {
      "type": "string"
    },
    "start_time": {
      "type": "string"
    },
    "end_time": {
      "type": "string"
    },
    "total_points": {
      "type": "number",
      "default": 0
    },
    "total_distance": {
      "type": "number",
      "default": 0
    },
    "upload_status": {
      "type": "string",
      "enum": [
        "pending",
        "uploaded",
        "linked",
        "error"
      ],
      "default": "pending"
    },
    "parsing_status": {
      "type": "string",
      "enum": [
        "not_started",
        "processing",
        "parsed",
        "needs_review",
        "error"
      ],
      "default": "not_started"
    },
    "notes": {
      "type": "string"
    },
    "created_by": {
      "type": "string"
    },
    "updated_by": {
      "type": "string"
    },
    "created_date": {
      "type": "string"
    },
    "updated_date": {
      "type": "string"
    }
  },
  "required": [
    "project_id",
    "source_type",
    "original_filename"
  ]
}
